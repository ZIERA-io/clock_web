# Supabase 커스텀 링크 & 로그인 기능 (선택 — 없어도 기본 시계 기능은 동작)
# 1. https://supabase.com 에서 프로젝트 생성
# 2. Project Settings > API 에서 값 복사
VITE_SUPABASE_URL=https://xxxxxxxxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Supabase SQL 에디터에서 아래 스키마 실행:
#
# CREATE TABLE public.links (
#   slug TEXT PRIMARY KEY CHECK (slug ~ '^[a-z0-9][a-z0-9-]{1,48}[a-z0-9]$'),
#   config JSONB NOT NULL,
#   user_id UUID REFERENCES auth.users(id) ON DELETE CASCADE,  -- NULL 허용: 익명 생성
#   created_at TIMESTAMPTZ DEFAULT NOW() NOT NULL
# );
# ALTER TABLE public.links ENABLE ROW LEVEL SECURITY;
# CREATE POLICY "read"   ON public.links FOR SELECT USING (true);
# CREATE POLICY "insert" ON public.links FOR INSERT WITH CHECK (true);  -- 누구나 생성 가능
# CREATE POLICY "update" ON public.links FOR UPDATE
#   USING (auth.uid() IS NOT NULL AND auth.uid() = user_id);  -- 본인 소유만 수정
#
# ※ URL 형태: https://도메인/a/<slug>  (Vercel 배포 시 vercel.json rewrite 자동 적용)
# ※ 로그인 없이도 슬러그 생성 가능. 단, 익명 슬러그는 이후 수정 불가.
#
# Authentication > Providers > Email 에서 "Confirm email" 을 OFF 로 설정하면
# 가입 즉시 로그인됩니다.
